{
  "name": "@varaperformance/backend",
  "version": "1.0.0",
  "description": "Vara Performance API backend — NestJS with Prisma and compliance-grade security",
  "author": "worlddrknss",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varaperformance/varaperformance.git",
    "directory": "apps/backend"
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:migrate:check:schema": "prisma migrate diff --from-config-datasource --to-schema prisma/schema --exit-code",
    "prisma:migrate:check:history": "prisma migrate diff --from-migrations prisma/migrations --to-config-datasource --exit-code",
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "pretest": "prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "link:setup": "rm -rf node_modules/zod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@infisical/sdk": "^4.0.6",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/qrcode": "^1.5.6",
    "@varaperformance/core": "workspace:*",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "apple-signin-auth": "^2.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "file-type": "^22.0.1",
    "google-auth-library": "^10.5.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.5.0",
    "nestjs-zod": "^5.1.1",
    "nodemailer": "^8.0.1",
    "otplib": "^13.4.0",
    "pg": "^8.18.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "prisma": "^7.3.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^18.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.9",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^otplib$": "<rootDir>/src/__mocks__/otplib.ts",
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/security(|/.*)$": "<rootDir>/libs/security/src/$1",
      "^@app/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@generated/prisma$": "<rootDir>/src/generated/prisma/client.ts",
      "^@generated/prisma/(.*)$": "<rootDir>/src/generated/prisma/$1",
      "^src/(.*)$": "<rootDir>/src/$1",
      "^\\./internal/(.*)\\.js$": "<rootDir>/src/generated/prisma/internal/$1.ts",
      "^\\./enums\\.js$": "<rootDir>/src/generated/prisma/enums.ts",
      "^\\./avatar\\.service\\.js$": "<rootDir>/libs/common/src/avatar/avatar.service.ts",
      "^\\./avatar\\.module\\.js$": "<rootDir>/libs/common/src/avatar/avatar.module.ts"
    },
    "watchman": false
  }
}
