# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mydatabase"

# Messaging
RABBITMQ_URL="amqp://guest:guest@localhost:5672"
WORKER_QUEUE="audit"

# Health monitor
BACKEND_URL="http://localhost:3000"
INTERNAL_API_KEY="change-me-in-production"
HEALTH_MONITOR_TIMEOUT_MS=10000

# Local AI Inference (Ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="gemma2:2b"
AI_STACK_TIPS_TIMEOUT_MS=60000

# Encryption (must match backend values)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEK=EXAMPLEKEYREPLACEME00000000000000000000000=
# Generate with: openssl ecparam -genkey -name prime256v1 -noout | openssl pkcs8 -topk8 -nocrypt
