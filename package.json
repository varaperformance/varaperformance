{
  "name": "@varaperformance/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Vara Performance monorepo",
  "author": "worlddrknss",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varaperformance/varaperformance.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @varaperformance/core build",
    "db:migrate:dev": "pnpm --filter @varaperformance/backend prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @varaperformance/backend prisma:migrate:deploy",
    "db:migrate:status": "pnpm --filter @varaperformance/backend prisma:migrate:status",
    "db:migrate:reset": "pnpm --filter @varaperformance/backend prisma:migrate:reset",
    "db:migrate:check:schema": "pnpm --filter @varaperformance/backend prisma:migrate:check:schema",
    "db:migrate:check:history": "pnpm --filter @varaperformance/backend prisma:migrate:check:history",
    "prisma:generate": "pnpm --filter @varaperformance/backend prisma:generate && pnpm --filter @varaperformance/worker prisma:generate",
    "dev:backend": "pnpm --filter @varaperformance/backend dev",
    "dev:web": "pnpm --filter @varaperformance/web dev",
    "dev:worker": "pnpm --filter @varaperformance/worker start:dev",
    "dev:workspace": "pnpm build:core && pnpm prisma:generate && pnpm --parallel --filter @varaperformance/backend --filter @varaperformance/worker --filter @varaperformance/web run start:dev",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @varaperformance/core test && pnpm --filter @varaperformance/web test && pnpm --filter @varaperformance/backend test && pnpm --filter @varaperformance/worker test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@capacitor/background-runner",
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "argon2",
      "cwebp-bin",
      "esbuild",
      "gifsicle",
      "jpegtran-bin",
      "mozjpeg",
      "optipng-bin",
      "pngquant-bin",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "auditConfig": {
      "ignoreCves": [
        "CVE-2022-37620"
      ]
    },
    "overrides": {
      "fast-xml-parser": ">=5.5.6",
      "rollup": ">=4.59.0",
      "defu": ">=6.1.5",
      "liquidjs": ">=10.25.3",
      "@xmldom/xmldom": ">=0.8.12",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "lodash@<4.18.0": ">=4.18.0",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "serialize-javascript": ">=7.0.3",
      "tar": ">=7.5.11",
      "flatted": ">=3.4.2",
      "undici@>=7.0.0 <8.0.0": ">=7.24.0 <8.0.0",
      "socket.io-parser": ">=4.2.6",
      "effect": ">=3.20.0",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "multer": ">=2.1.1"
    }
  }
}
