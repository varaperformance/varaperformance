{
  "name": "@varaperformance/core",
  "version": "1.0.0",
  "description": "Vara Performance shared Zod schemas, TypeScript interfaces, and core types",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varaperformance/varaperformance.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "author": "worlddrknss",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
